<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppCompat parent مطلوب لعمل تبديل اللغة (setApplicationLocales) على كل الإصدارات -->
    <style name="Theme.RafiqAlDhikr"
           parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/cream_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.RafiqAlDhikr.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.RafiqAlDhikr</item>
    </style>
</resources>
